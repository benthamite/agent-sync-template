{
  "global": {
    "file_pairs": [
      {
        "name": "global instructions",
        "claude": "~/path/to/claude/CLAUDE.md",
        "codex": "~/path/to/codex/AGENTS.md",
        "normalizer": "instructions"
      }
    ],
    "skill_roots": [
      {
        "name": "global skills",
        "claude": "~/path/to/claude/skills",
        "codex": "~/path/to/codex/skills"
      }
    ],
    "hook_roots": [
      {
        "name": "global hooks",
        "claude": "~/path/to/claude/hooks",
        "codex": "~/path/to/codex/hooks"
      }
    ],
    "registration_pairs": [
      {
        "name": "hook registrations",
        "claude": "~/.claude/settings.json",
        "codex": "~/.codex/hooks.json"
      }
    ]
  },
  "project_local": {
    "what_to_do": "The setup agent should infer one choice: leave this unchanged if project-local files use .claude/ and .codex/ or if no project-local files are currently used; edit these paths if project-local files use different directories; set skill_roots, hook_roots, and registration_pairs to [] if project-local checks are not wanted. This section is a conditional rule for the current git repo, not a request to create directories.",
    "skill_roots": [
      {
        "name": "project-local skills",
        "claude": ".claude/skills",
        "codex": ".codex/skills"
      }
    ],
    "hook_roots": [
      {
        "name": "project-local hooks",
        "claude": ".claude/hooks",
        "codex": ".codex/hooks"
      }
    ],
    "registration_pairs": [
      {
        "name": "project-local hook registrations",
        "claude": ".claude/settings.json",
        "codex": ".codex/hooks.json"
      }
    ]
  },
  "ignore": [
    "**/.DS_Store",
    "**/__pycache__/**",
    "**/*.pyc",
    "**/tmp/**",
    "**/cache/**"
  ]
}
