#!/usr/bin/env python3
"""Keep existing Claude Code and Codex files synchronized by path mapping."""

from __future__ import annotations

import fnmatch
import json
import os
import re
import shlex
import subprocess
import sys
from pathlib import Path
from typing import Callable

ROOT = Path(__file__).resolve().parents[1]


def run_git(repo: Path, *args: str) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", "-C", str(repo), *args],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def git_root(start: Path) -> Path | None:
    proc = subprocess.run(
        ["git", "-C", str(start), "rev-parse", "--show-toplevel"],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )
    if proc.returncode != 0:
        return None
    return Path(proc.stdout.strip()).resolve()


def split_args(argv: list[str]) -> tuple[str, Path | None, list[str]]:
    args = list(argv[1:])
    config: Path | None = None
    rest: list[str] = []
    while args:
        arg = args.pop(0)
        if arg == "--config":
            if not args:
                raise SystemExit("--config requires a path")
            config = Path(args.pop(0))
        else:
            rest.append(arg)
    command = rest.pop(0) if rest else "audit"
    return command, config, rest


def find_config(explicit: Path | None) -> Path:
    if explicit is not None:
        return explicit.expanduser().resolve()
    env = os.environ.get("AGENT_SYNC_CONFIG")
    if env:
        return Path(env).expanduser().resolve()
    for start in [Path.cwd(), *Path.cwd().parents]:
        candidate = start / "ai-config-sync.json"
        if candidate.exists():
            return candidate.resolve()
    candidate = ROOT / "ai-config-sync.json"
    if candidate.exists():
        return candidate.resolve()
    raise RuntimeError(
        "No ai-config-sync.json found. Copy ai-config-sync.example.json, edit the paths, "
        "or pass --config PATH."
    )


def load_config(path: Path) -> dict:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception as exc:
        raise RuntimeError(f"Could not read {path}: {exc}") from exc


def expand_path(raw: str, base: Path) -> Path:
    text = os.path.expandvars(os.path.expanduser(raw))
    path = Path(text)
    if not path.is_absolute():
        path = base / path
    return path.resolve()


def normalize_frontmatter(text: str) -> str:
    if not text.startswith("---\n"):
        return text
    end = text.find("\n---\n", 4)
    if end == -1:
        return text
    front = text[4:end].splitlines()
    body = text[end + 5 :]
    ignored = re.compile(
        r"^(allowed-tools|argument-hint|model|tools|user-invocable|argument-metadata):\s*",
        re.I,
    )
    front = [line for line in front if not ignored.match(line)]
    return "---\n" + "\n".join(front).strip() + "\n---\n" + body


def normalize_text(text: str) -> str:
    text = text.replace("\r\n", "\n")
    text = normalize_frontmatter(text)
    text = text.replace("Claude Code and Codex", "Claude/Codex")
    text = text.replace("Claude and Codex", "Claude/Codex")
    text = text.replace("Claude Code", "Claude")
    text = re.sub(r"[ \t]+\n", "\n", text)
    return text.strip() + "\n"


def normalize_instructions(text: str) -> str:
    text = normalize_text(text)
    text = re.sub(r"^# .*Claude.*$", "# Global agent instructions", text, flags=re.M)
    text = re.sub(r"^# .*Codex.*$", "# Global agent instructions", text, flags=re.M)
    return text


def normalize_hook(text: str) -> str:
    text = normalize_text(text)
    text = text.replace("remind-claude", "remind-agent")
    text = text.replace("remind-codex", "remind-agent")
    return text


def normalizer(name: str | None) -> Callable[[str], str]:
    if name == "instructions":
        return normalize_instructions
    if name == "hooks":
        return normalize_hook
    return normalize_text


def ignored(rel: str, patterns: list[str]) -> bool:
    return any(fnmatch.fnmatch(rel, pattern) for pattern in patterns)


def display(path: Path) -> str:
    try:
        return path.relative_to(Path.cwd()).as_posix()
    except ValueError:
        return str(path)


def compare_files(
    left: Path,
    right: Path,
    label: str,
    normalize: Callable[[str], str] = normalize_text,
) -> list[str]:
    problems: list[str] = []
    left_exists = left.exists()
    right_exists = right.exists()
    if not left_exists and not right_exists:
        return problems
    if not left_exists:
        return [f"{label}: missing Claude path {left}"]
    if not right_exists:
        return [f"{label}: missing Codex path {right}"]
    if normalize(left.read_text(encoding="utf-8")) != normalize(
        right.read_text(encoding="utf-8")
    ):
        problems.append(f"{label}: drift between {left} and {right}")
    return problems


def files_under(root: Path, patterns: list[str]) -> set[str]:
    if not root.exists():
        return set()
    return {
        path.relative_to(root).as_posix()
        for path in root.rglob("*")
        if path.is_file() and not ignored(path.relative_to(root).as_posix(), patterns)
    }


def skill_names(root: Path) -> set[str]:
    if not root.exists():
        return set()
    return {
        child.name
        for child in root.iterdir()
        if child.is_dir() and (child / "SKILL.md").exists()
    }


def compare_skill_roots(item: dict, base: Path, patterns: list[str]) -> list[str]:
    left = expand_path(item["claude"], base)
    right = expand_path(item["codex"], base)
    name = item.get("name", "skills")
    problems: list[str] = []
    if not left.exists():
        problems.append(f"{name}: missing Claude skill root {left}")
    if not right.exists():
        problems.append(f"{name}: missing Codex skill root {right}")
    if problems:
        return problems
    left_names = skill_names(left)
    right_names = skill_names(right)
    for missing in sorted(left_names - right_names):
        problems.append(f"{name}: missing Codex skill for {missing}")
    for missing in sorted(right_names - left_names):
        problems.append(f"{name}: missing Claude skill for {missing}")
    for skill in sorted(left_names & right_names):
        ldir = left / skill
        rdir = right / skill
        lfiles = files_under(ldir, patterns)
        rfiles = files_under(rdir, patterns)
        for missing in sorted(lfiles - rfiles):
            problems.append(f"{name}/{skill}: missing Codex file {missing}")
        for missing in sorted(rfiles - lfiles):
            problems.append(f"{name}/{skill}: missing Claude file {missing}")
        for rel in sorted(lfiles & rfiles):
            problems.extend(
                compare_files(ldir / rel, rdir / rel, f"{name}/{skill}/{rel}")
            )
    return problems


def compare_file_roots(
    item: dict,
    base: Path,
    patterns: list[str],
    normalize: Callable[[str], str],
) -> list[str]:
    left = expand_path(item["claude"], base)
    right = expand_path(item["codex"], base)
    name = item.get("name", "files")
    problems: list[str] = []
    if not left.exists():
        problems.append(f"{name}: missing Claude root {left}")
    if not right.exists():
        problems.append(f"{name}: missing Codex root {right}")
    if problems:
        return problems
    lfiles = files_under(left, patterns)
    rfiles = files_under(right, patterns)
    for missing in sorted(lfiles - rfiles):
        problems.append(f"{name}: missing Codex file {missing}")
    for missing in sorted(rfiles - lfiles):
        problems.append(f"{name}: missing Claude file {missing}")
    for rel in sorted(lfiles & rfiles):
        problems.extend(compare_files(left / rel, right / rel, f"{name}/{rel}", normalize))
    return problems


def audit(config: dict, base: Path) -> list[str]:
    problems: list[str] = []
    patterns = config.get("ignore", [])
    global_cfg = config.get("global", {})

    for item in global_cfg.get("file_pairs", []):
        problems.extend(
            compare_files(
                expand_path(item["claude"], base),
                expand_path(item["codex"], base),
                item.get("name", "file pair"),
                normalizer(item.get("normalizer")),
            )
        )

    for item in global_cfg.get("skill_roots", []):
        problems.extend(compare_skill_roots(item, base, patterns))

    for item in global_cfg.get("hook_roots", []):
        problems.extend(compare_file_roots(item, base, patterns, normalize_hook))

    for item in global_cfg.get("registration_pairs", []):
        left = expand_path(item["claude"], base)
        right = expand_path(item["codex"], base)
        name = item.get("name", "registration pair")
        if not left.exists():
            problems.append(f"{name}: missing Claude registration file {left}")
        if not right.exists():
            problems.append(f"{name}: missing Codex registration file {right}")
    return problems


def inventory(config: dict, base: Path) -> list[str]:
    problems = audit(config, base)
    if not problems:
        return ["No missing or drifting global pairs found."]
    return problems


def staged_paths(repo: Path) -> set[Path]:
    proc = run_git(repo, "diff", "--cached", "--name-only", "--diff-filter=ACMR")
    if proc.returncode != 0:
        return set()
    return {(repo / line).resolve() for line in proc.stdout.splitlines() if line}


def changed_paths(repo: Path) -> set[Path]:
    paths: set[Path] = set()
    for args in (
        ("diff", "--name-only", "--diff-filter=ACMR"),
        ("diff", "--cached", "--name-only", "--diff-filter=ACMR"),
        ("ls-files", "--others", "--exclude-standard"),
    ):
        proc = run_git(repo, *args)
        if proc.returncode == 0:
            paths.update((repo / line).resolve() for line in proc.stdout.splitlines() if line)
    return paths


def same_or_under(path: Path, root: Path) -> str | None:
    try:
        return path.relative_to(root).as_posix()
    except ValueError:
        return None


def add_exact_pair(pairs: dict[Path, Path], left: Path, right: Path) -> None:
    pairs[left.resolve()] = right.resolve()
    pairs[right.resolve()] = left.resolve()


def counterpart_pairs_for_repo(config: dict, base: Path, repo: Path) -> dict[Path, Path]:
    pairs: dict[Path, Path] = {}
    global_cfg = config.get("global", {})
    for item in global_cfg.get("file_pairs", []) + global_cfg.get("registration_pairs", []):
        add_exact_pair(pairs, expand_path(item["claude"], base), expand_path(item["codex"], base))

    for key in ("skill_roots", "hook_roots"):
        for item in global_cfg.get(key, []):
            left = expand_path(item["claude"], base)
            right = expand_path(item["codex"], base)
            for path in staged_paths(repo) | changed_paths(repo):
                rel = same_or_under(path, left)
                if rel is not None:
                    add_exact_pair(pairs, path, right / rel)
                rel = same_or_under(path, right)
                if rel is not None:
                    add_exact_pair(pairs, path, left / rel)

    local_cfg = config.get("project_local", {})
    for item in local_cfg.get("registration_pairs", []):
        add_exact_pair(pairs, repo / item["claude"], repo / item["codex"])
    for key in ("skill_roots", "hook_roots"):
        for item in local_cfg.get(key, []):
            left = (repo / item["claude"]).resolve()
            right = (repo / item["codex"]).resolve()
            for path in staged_paths(repo) | changed_paths(repo):
                rel = same_or_under(path, left)
                if rel is not None:
                    add_exact_pair(pairs, path, right / rel)
                rel = same_or_under(path, right)
                if rel is not None:
                    add_exact_pair(pairs, path, left / rel)
    return pairs


def command_text(args: list[str]) -> str:
    if args:
        return " ".join(args)
    raw = sys.stdin.read()
    if not raw.strip():
        return ""
    try:
        payload = json.loads(raw)
    except Exception:
        return raw
    tool_input = payload.get("tool_input") or payload.get("toolInput") or {}
    if isinstance(tool_input, dict) and isinstance(tool_input.get("command"), str):
        return tool_input["command"]
    if isinstance(payload.get("command"), str):
        return payload["command"]
    return raw


def git_command_repo(command: str) -> Path | None:
    try:
        tokens = shlex.split(command)
    except ValueError:
        tokens = command.split()
    cwd = Path.cwd()
    for i, token in enumerate(tokens):
        if token != "git":
            continue
        tail = tokens[i + 1 :]
        while tail:
            if tail[0] == "-C" and len(tail) >= 2:
                target = Path(tail[1])
                cwd = target if target.is_absolute() else cwd / target
                tail = tail[2:]
                continue
            if tail[0] in {"-c", "--config-env"} and len(tail) >= 2:
                tail = tail[2:]
                continue
            if tail[0].startswith("-"):
                tail = tail[1:]
                continue
            break
        return git_root(cwd)
    return git_root(Path.cwd())


def is_git_commit(command: str) -> bool:
    try:
        tokens = shlex.split(command)
    except ValueError:
        tokens = command.split()
    for i, token in enumerate(tokens):
        if token != "git":
            continue
        tail = tokens[i + 1 :]
        while tail and tail[0] == "-C" and len(tail) >= 2:
            tail = tail[2:]
        return bool(tail and tail[0] == "commit")
    return False


def one_sided_messages(config: dict, base: Path, repo: Path, paths: set[Path]) -> list[str]:
    pairs = counterpart_pairs_for_repo(config, base, repo)
    messages: list[str] = []
    for path in sorted(paths):
        other = pairs.get(path.resolve())
        if other and other.resolve() not in {p.resolve() for p in paths}:
            messages.append(
                f"{display(path)} changed without its Claude/Codex counterpart: {display(other)}"
            )
    return messages


def guard_commit(config: dict, base: Path, args: list[str]) -> int:
    command = command_text(args)
    if command and not is_git_commit(command):
        return 0
    repo = git_command_repo(command) if command else git_root(Path.cwd())
    if repo is None:
        return 0
    messages = one_sided_messages(config, base, repo, staged_paths(repo))
    if not messages:
        return 0
    print("Claude/Codex sync guard blocked this commit:", file=sys.stderr)
    for message in messages:
        print(f"- {message}", file=sys.stderr)
    print("Update the counterpart or unstage the one-sided change.", file=sys.stderr)
    return 2


def payload_paths(payload: dict) -> list[str]:
    paths: list[str] = []

    def visit(value):
        if isinstance(value, dict):
            for key, child in value.items():
                if key in {"file_path", "path"} and isinstance(child, str):
                    paths.append(child)
                else:
                    visit(child)
        elif isinstance(value, list):
            for child in value:
                visit(child)

    visit(payload)
    return paths


def remind(config: dict, base: Path, args: list[str]) -> int:
    agent = "claude"
    if "--agent" in args:
        index = args.index("--agent")
        if index + 1 < len(args):
            agent = args[index + 1]

    repo = git_root(Path.cwd())
    if repo is None:
        return 0
    raw = sys.stdin.read()
    explicit: set[Path] = set()
    if raw.strip():
        try:
            payload = json.loads(raw)
        except Exception:
            payload = {}
        for value in payload_paths(payload):
            path = Path(value)
            if not path.is_absolute():
                path = Path.cwd() / path
            explicit.add(path.resolve())

    paths = explicit or changed_paths(repo)
    messages = one_sided_messages(config, base, repo, paths)
    text = ""
    if messages:
        text = "Claude/Codex sync reminder:\n" + "\n".join(f"- {m}" for m in messages)
    if agent == "codex":
        print(json.dumps({"hookSpecificOutput": {"additionalContext": text}}))
    elif text:
        print(text)
    return 0


def print_problems(problems: list[str], label: str) -> int:
    if not problems:
        print(f"{label}: ok")
        return 0
    print(f"{label}: found {len(problems)} problem(s)", file=sys.stderr)
    for problem in problems:
        print(f"- {problem}", file=sys.stderr)
    return 1


def main(argv: list[str]) -> int:
    try:
        command, explicit_config, args = split_args(argv)
        config_path = find_config(explicit_config)
        config = load_config(config_path)
        base = config_path.parent
        if command == "audit":
            return print_problems(audit(config, base), "audit")
        if command == "inventory":
            for line in inventory(config, base):
                print(line)
            return 0
        if command == "guard-commit":
            return guard_commit(config, base, args)
        if command == "remind":
            return remind(config, base, args)
    except RuntimeError as exc:
        print(str(exc), file=sys.stderr)
        return 1

    print(
        "usage: ai-config-sync [--config PATH] "
        "[audit|inventory|guard-commit|remind --agent claude|codex]",
        file=sys.stderr,
    )
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
