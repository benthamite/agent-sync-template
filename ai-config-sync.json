{
  "instructions": [
    {
      "name": "global-instructions",
      "claude": "claude/CLAUDE.md",
      "codex": "codex/AGENTS.md",
      "status": "paired",
      "equivalence": "The headings may name the tool, but the operational rules should be the same."
    }
  ],
  "skills": [
    {
      "name": "example",
      "claude": "claude/skills/example",
      "codex": "codex/skills/example",
      "status": "paired",
      "equivalence": "The Claude and Codex skill bodies should describe the same workflow. Tool-specific frontmatter may differ."
    }
  ],
  "hooks": [
    {
      "name": "remind-ai-config-sync",
      "claude": "claude/hooks/remind-ai-config-sync.sh",
      "codex": "codex/hooks/remind-ai-config-sync.sh",
      "status": "paired"
    },
    {
      "name": "require-ai-config-sync",
      "claude": "claude/hooks/require-ai-config-sync.sh",
      "codex": "codex/hooks/require-ai-config-sync.sh",
      "status": "paired"
    }
  ],
  "registrations": [
    {
      "tool": "claude",
      "path": "~/.claude/settings.json",
      "status": "mutable-live",
      "note": "Claude Code writes mutable settings here, so install.sh merges hook registrations instead of symlinking the file."
    },
    {
      "tool": "codex",
      "path": "codex/hooks.json",
      "live_path": "~/.codex/hooks.json",
      "status": "tracked-live"
    },
    {
      "tool": "codex",
      "path": "codex/config.toml",
      "live_path": "~/.codex/config.toml",
      "status": "tracked-live"
    },
    {
      "tool": "codex",
      "path": "codex/rules/default.rules",
      "live_path": "~/.codex/rules/default.rules",
      "status": "codex-only",
      "note": "Codex can load supplemental rule files through config.toml. Claude Code has no direct equivalent in this template."
    }
  ],
  "audit_command": "bin/ai-config-sync audit"
}
